        <mxCell id="S9mtPsG4A-c3wudoXRGy-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Design a Whatsaap system with proper following requirements:&lt;div&gt;1.user service&lt;/div&gt;&lt;div&gt;2.chat service&lt;/div&gt;&lt;div&gt;3.group service&lt;/div&gt;&lt;div&gt;optimize the chat service for handling millions of request&lt;/div&gt;&lt;div&gt;specify type of connection used in design&lt;/div&gt;&lt;div&gt;determine how the design will done for last seen fucntionality&lt;/div&gt;&lt;div&gt;Implement CDC pipeline in same architecture&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="430" x="290" y="-1070" as="geometry" />
        </mxCell>
        <mxCell id="S9mtPsG4A-c3wudoXRGy-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h1 style=&quot;text-align: left; margin-top: 0px;&quot;&gt;Functional Requirements:&lt;/h1&gt;&lt;p style=&quot;text-align: left;&quot;&gt;1.User should be able to login/logout whatsapp.&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;2.User should be able to send messages to other users.&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;3.User should be able to search friend&#39;s name.&lt;/p&gt;&lt;p style=&quot;text-align: left;&quot;&gt;4.User should be able to see old messages.&lt;/p&gt;" vertex="1">
          <mxGeometry height="220" width="550" x="20" y="-900" as="geometry" />
        </mxCell>
        <mxCell id="OEuflJUAH7KoRobzY16_-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Non Functional Requirements:&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 12px; font-weight: normal;&quot;&gt;1.Total possible Users:&amp;nbsp; 1.5 million&lt;/span&gt;&lt;/h1&gt;&lt;p&gt;2.Availability:&amp;nbsp; System should be available for all users.&lt;/p&gt;&lt;p&gt;3.Scalability:&amp;nbsp; System should be scalable if load increases.&lt;/p&gt;&lt;p&gt;we use either horizontal or vertical scaling&lt;/p&gt;&lt;p&gt;4.Consistency:&amp;nbsp; System should be consistent&lt;/p&gt;&lt;p&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="220" width="520" x="60" y="-700" as="geometry" />
        </mxCell>
        <mxCell id="OEuflJUAH7KoRobzY16_-2" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;API Design&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;text-align: center; text-wrap-mode: nowrap; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Registering a user&lt;/span&gt;&lt;/p&gt;&lt;div&gt;1.POST:https://www.whatsapp.com/user/register&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;.Body:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;{&lt;/span&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; userName,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; email,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; phoneNumber&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2.&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;one to one messaging:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;A.WS(Web Socket)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;B.GET:List&amp;lt;Chat&amp;gt;.&amp;nbsp; (List of all chats)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;C.GET:/messages/{userId}/{recieverId}.&amp;nbsp; (when user clicks on specific chat then all messages appears.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;3.Group Messsages:&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&amp;nbsp; &amp;nbsp;Create a group&lt;br&gt;&amp;nbsp; A.POST/group/create&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&amp;nbsp; &amp;nbsp; ADD member&lt;br&gt;&amp;nbsp; B.POST/group/groupID/add&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-wrap-mode: nowrap; text-align: center; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp;Remove member&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-wrap-mode: nowrap; text-align: center; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; C.Delete/groups/{groupID/remove&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="500" width="570" x="140" y="-430" as="geometry" />
        </mxCell>
